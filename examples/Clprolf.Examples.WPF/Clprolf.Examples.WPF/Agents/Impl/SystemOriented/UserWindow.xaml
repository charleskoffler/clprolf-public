<Window x:Class="Clprolf.Examples.WPF.Agents.Impl.SystemOriented.UserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Clprolf.Examples.WPF"
        mc:Ignorable="d"
        Title="UserWindow" Height="450" Width="800">
    <StackPanel Margin="20">

        <!-- LIST -->
        <ListBox ItemsSource="{Binding Users}"
                 SelectedItem="{Binding SelectedUser}"
                 DisplayMemberPath="Name"
                 Height="150"/>

        <!-- ADDITIONS -->
        <TextBox Text="{Binding NewUserName}" Margin="0,10,0,0"/>
        <Button Content="Add" Command="{Binding AddCommand}"/>

        <!-- ACTIONS -->
        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="Update" Command="{Binding UpdateCommand}" Margin="0,0,10,0"/>
            <Button Content="Delete" Command="{Binding DeleteCommand}"/>
        </StackPanel>

    </StackPanel>

</Window>
